{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/warn-destructive.js\""
          }
        ],
        "description": "Block destructive shell commands (rm -rf, git reset --hard, DROP TABLE, etc.)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/auto-format-python.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Auto-format Python files with ruff/black after write or edit"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/desktop-notify.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "macOS notification with tmux click-to-pane on task completion"
      }
    ]
  }
}
