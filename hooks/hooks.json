{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-reporter.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Register agent in dashboard on session start"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/warn-destructive.js\""
          }
        ],
        "description": "Block destructive shell commands (rm -rf, git reset --hard, DROP TABLE, etc.)"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-fast.js\"",
            "async": true,
            "timeout": 3
          }
        ],
        "description": "Fast state sync for dashboard (state, permission_mode, current_tool)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/commit-lint.js\""
          }
        ],
        "description": "Validate conventional commit message format on git commit"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/test-gate.js\""
          }
        ],
        "description": "Block git commit unless make test passes (set SKIP_TEST_GATE=1 to bypass)"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-fast.js\"",
            "async": true,
            "timeout": 3
          }
        ],
        "description": "Fast state sync for dashboard"
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-fast.js\"",
            "async": true,
            "timeout": 3
          }
        ],
        "description": "Instant needs-attention detection for dashboard"
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-reporter.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Track subagent spawn in dashboard"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-reporter.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Track subagent completion in dashboard"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        {
          "type": "command",
          "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/agent-state-reporter.js\"",
          "async": true,
          "timeout": 5
        }
      ],
      "description": "Desktop notification + agent state reporting; Blow sound when AskUserQuestion or ExitPlanMode detected"
    }
  ],
  "Notification": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/desktop-notify.js\"",
          "async": true,
          "timeout": 10
        }
      ],
      "description": "Blow sound on permission prompt, idle prompt, or elicitation dialog"
    }
  ],
  "StopFailure": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/desktop-notify.js\"",
          "async": true,
          "timeout": 10
        }
      ],
      "description": "Blow sound on rate limit errors"
    }
  ]
}
}